<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="2026-03-02-Males.database" author="Dmitry">
        <createTable tableName="Males">
            <column name="id" type="BIGINT">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="Exercise_id" type="BIGINT">
                <constraints nullable="false" unique="false" references="Exercise(id)" foreignKeyName="fk_Males_Exercise"/>
            </column>
            <column name="Male_id" type="BIGINT">
                <constraints nullable="false" unique="false" references="Male(id)" foreignKeyName="fk_Males_Male"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>