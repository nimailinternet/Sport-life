<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <changeSet id="2026-03-02-Favourites.xml" author="Dmitry">
        <createTable tableName="Favourites">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="Exercise_id" type="BIGINT">
                <constraints nullable="false" unique="false" references="Exercise(id)" foreignKeyName="fk_Favourites_Exercise"/>
            </column>
            <column name="Employee_id" type="BIGINT">
                <constraints nullable="false" unique="false" references="Employee(id)" foreignKeyName="fk_Favourites_Employee"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>